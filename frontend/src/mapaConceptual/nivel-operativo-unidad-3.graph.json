      "label": "Punto de equilibrio",
      "depth": 2
    },
    {
      "id": "n149",
      "label": "Es el nivel de ventas en el cual los ingresos obtenidos son iguales a los costos de producción, tanto fijos como variables. Es el nivel de ventas en el cual la empresa ni gana ni pierde.",
      "depth": 3
    },
    {
      "id": "n150",
      "label": "Punto de equilibrio en Unidades = CF / (PVu - CVu)",
